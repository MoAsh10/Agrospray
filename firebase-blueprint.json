{
  "entities": {
    "SummaryStats": {
      "title": "Summary Statistics",
      "description": "System-wide real-time metrics",
      "type": "object",
      "properties": {
        "activeDevices": { "type": "number" },
        "spraysToday": { "type": "number" },
        "chemicalUsage": { "type": "number" },
        "waterUsage": { "type": "number" },
        "alertsCount": { "type": "number" },
        "healthScore": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["activeDevices", "spraysToday", "chemicalUsage", "waterUsage", "alertsCount", "healthScore"]
    },
    "Device": {
      "title": "IoT Spray Device",
      "description": "Telemetry and status for an individual spray unit",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "error"] },
        "battery": { "type": "number" },
        "lastActive": { "type": "string" },
        "flowRate": { "type": "number" },
        "pumpStatus": { "type": "boolean" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["id", "name", "status", "battery"]
    },
    "SprayLog": {
      "title": "Spray Operation Log",
      "description": "Record of a single spray cycle",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "duration": { "type": "string" },
        "areaCovered": { "type": "string" },
        "chemicalUsed": { "type": "string" },
        "status": { "type": "string", "enum": ["completed", "interrupted", "in-progress"] }
      },
      "required": ["id", "date", "status"]
    },
    "Alert": {
      "title": "System Alert",
      "description": "Notification or warning from the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["critical", "warning", "info"] },
        "time": { "type": "string" },
        "isRead": { "type": "boolean" }
      },
      "required": ["id", "title", "severity", "isRead"]
    }
  },
  "firestore": {
    "/stats/summary": {
      "schema": "SummaryStats",
      "description": "Global system statistics"
    },
    "/devices/{deviceId}": {
      "schema": "Device",
      "description": "Individual device telemetry"
    },
    "/logs/{logId}": {
      "schema": "SprayLog",
      "description": "Historical spray operation logs"
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "System alerts and notifications"
    }
  }
}
